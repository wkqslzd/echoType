generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CourseMode {
  SHORT
  ARTICLE
}

model User {
  id        String   @id @default(cuid())
  email     String?  @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categories Category[]
  courses    Course[]
  sessions   TypingSession[]

  @@map("users")
}

model Category {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  mode        CourseMode
  description String?  @db.VarChar(1000)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  courses Course[]

  @@unique([userId, mode, name])
  @@index([userId])
  @@map("categories")
}

model Course {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  title      String
  content    String
  mode       CourseMode
  description String? @db.VarChar(1000)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  totalDurationSec      Int       @default(0)
  totalCompletedPasses  Int       @default(0)
  sessionCount          Int       @default(0)
  totalCharCount        Int       @default(0)
  totalWpmCharSum       Float     @default(0)
  totalAccCharSum       Float     @default(0)
  lastPracticedAt       DateTime?

  annotations Annotation[]
  sessions    TypingSession[]

  @@unique([userId, mode, title])
  @@index([userId, mode, createdAt])
  @@index([userId, mode, lastPracticedAt])
  @@index([userId, mode, totalCompletedPasses])
  @@index([userId, mode, totalDurationSec])
  @@map("courses")
}

model Annotation {
  id           String   @id @default(cuid())
  courseId     String
  course       Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  startIndex   Int
  endIndex     Int
  noteText     String
  anchoredText String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([courseId])
  @@map("annotations")
}

model TypingSession {
  id           String   @id @default(cuid())
  courseId     String
  course       Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  startedAt    DateTime
  endedAt      DateTime
  durationSec  Int
  charCount    Int
  errorCount   Int
  wpm          Float
  accuracy     Float
  loopCount    Int      @default(0)
  pasteRanges  Json     @default("[]")

  createdAt    DateTime @default(now())

  @@index([courseId, createdAt])
  @@index([userId, createdAt])
  @@map("typing_sessions")
}
