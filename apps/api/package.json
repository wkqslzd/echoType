{
  "name": "@echotype/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:reset": "prisma migrate reset --force",
    "prisma:studio": "prisma studio",
    "seed": "tsx prisma/seed.ts",
    "test:auth": "node --import tsx --test src/auth/ensureUser.test.ts src/auth/federatedLink.test.ts src/auth/cognitoUserProfile.test.ts src/routes/account.test.ts src/routes/onboarding.test.ts ../../packages/shared/src/cognitoOAuth.test.ts ../../packages/shared/src/onboardingCatalog.test.ts ../../packages/shared/src/onboardingSeed.test.ts",
    "probe:auth": "node scripts/auth-phase3-jwt-probe.mjs",
    "test:sentry": "node --import tsx --test src/sentry.test.ts",
    "probe:ops-sentry": "node scripts/ops-sentry-probe.mjs",
    "test:auth-google-phase1": "pnpm --filter @echotype/shared exec node --import tsx --test src/cognitoOAuth.test.ts",
    "probe:auth-google-phase1": "node --import tsx scripts/auth-google-phase1-probe.mjs",
    "test:auth-google-phase2": "pnpm --filter @echotype/shared exec node --import tsx --test src/cognitoOAuth.test.ts && pnpm --filter @echotype/api exec node --import tsx --test src/auth/federatedLink.test.ts src/auth/ensureUser.test.ts src/auth/cognitoUserProfile.test.ts",
    "probe:auth-google-phase2": "node --import tsx scripts/auth-google-phase2-probe.mjs",
    "probe:auth-google-phase2-local-link": "node scripts/auth-google-phase2-local-link-probe.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.1077.0",
    "@echotype/shared": "workspace:*",
    "@fastify/cors": "^10.0.1",
    "@prisma/client": "^5.22.0",
    "@sentry/node": "^10.64.0",
    "aws-jwt-verify": "^5.2.1",
    "fastify": "^5.1.0",
    "pino-pretty": "^11.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
